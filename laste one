// Top quartile >75% = next 10 days SPY -0.04%
function updateBreadth200Card() {
  const d = window.breadth200Data;
  if(!d || d.current === null) return;
  const card  = document.getElementById('breadth200Card');
  const label = document.getElementById('breadth200Label');
  const sub   = document.getElementById('breadth200Sub');
  const desc  = document.getElementById('breadth200Desc');
  const val   = d.current;

  if(val >= 75) {
    card.style.background = '#1a0a02';
    card.style.border     = '1px solid #f9731650';
    label.style.color     = '#f97316';
    label.textContent     = val + '%  TOP QUARTILE';
    sub.style.color       = '#f97316';
    sub.textContent       = 'OVERBOUGHT — NEXT 10 DAYS -0.04%';
    desc.textContent      = 'Above 75% — Dr S top quartile. Next 10 days SPY historically -0.04%. Do not chase. Bull market extended. Take profits. Wait for pullback.';
  } else if(val <= 25) {
    card.style.background = '#021408';
    card.style.border     = '1px solid #22c55e50';
    label.style.color     = '#22c55e';
    label.textContent     = val + '%  BOTTOM QUARTILE';
    sub.style.color       = '#22c55e';
    sub.textContent       = 'OVERSOLD — NEXT 10 DAYS +1.32%';
    desc.textContent      = 'Below 25% — Dr S bottom quartile. Next 10 days SPY historically +1.32% — strongest long term bounce edge. Structural oversold. High conviction setup when combined with 50D and BB signals.';
  } else if(val >= 50) {
    card.style.background = '#0a1a2a';
    card.style.border     = '1px solid #38bdf830';
    label.style.color     = '#38bdf8';
    label.textContent     = val + '%  UPPER HALF';
    sub.style.color       = '#38bdf8';
    sub.textContent       = 'HEALTHY LONG TERM';
    desc.textContent      = 'Above 50%. Long term market structure healthy. Bull market intact. No special edge from 200D breadth alone.';
  } else {
    card.style.background = '#1a0a02';
    card.style.border     = '1px solid #f9731630';
    label.style.color     = '#f97316';
    label.textContent     = val + '%  LOWER HALF';
    sub.style.color       = '#f97316';
    sub.textContent       = 'STRUCTURAL WEAKNESS';
    desc.textContent      = 'Between 25-50%. Long term breadth weakening. Watch for drop below 25% for the +1.32% edge to activate. Approaching bear market territory.';
  }
}

// ── PCRE EQUITY PUT/CALL QUARTILE — Dr Steenbarger sentiment rule ──
// 10-year data quartiles (2016-2026, n=2514):
// Bottom quartile ≤ 0.53 → next 10 days SPY +0.25% (greed/complacent, subnormal)
// Top quartile    ≥ 0.68 → next 10 days SPY +0.96% (fear/panic, edge active)
// Middle 50%     0.53-0.68 → no edge
function updatePcreCard() {
  const card  = document.getElementById('pcreCard');
  const label = document.getElementById('pcreLabel');
  const sub   = document.getElementById('pcreSub');
  const desc  = document.getElementById('pcreDesc');
  const input = document.getElementById('pcreInput');
  const val   = parseFloat(input.value);
  if(isNaN(val)) return;
  window.pcreValue = val;

  // Use live-calculated quartiles if available, fall back to defaults
  const q25 = window.pcreQ25 ?? 0.53;
  const q75 = window.pcreQ75 ?? 0.68;
  const srcLabel = window.pcreData ? 'live' : 'fallback';

  // Refresh threshold display at bottom of card
  const q25L = document.getElementById('pcreQ25Label');
  const q75L = document.getElementById('pcreQ75Label');
  const midL = document.getElementById('pcreMidLabel');
  const srcL = document.getElementById('pcreThreshSource');
  if(q25L) q25L.textContent = '≤ ' + q25.toFixed(2);
  if(q75L) q75L.textContent = '≥ ' + q75.toFixed(2);
  if(midL) midL.textContent = q25.toFixed(2) + ' – ' + q75.toFixed(2);
  if(srcL && window.pcreData) srcL.textContent = '(LIVE, n=' + window.pcreData.n + ')';

  if(val >= q75) {
    card.style.background = '#021408';
    card.style.border     = '1px solid #22c55e50';
    label.style.color     = '#22c55e';
    label.textContent     = val.toFixed(2) + '  TOP QUARTILE';
    sub.style.color       = '#22c55e';
    sub.textContent       = 'FEAR — NEXT 10 DAYS SPY +0.96%';
    desc.textContent      = 'Today\'s $PCRE = ' + val.toFixed(2) + ' → TOP QUARTILE (≥ ' + q75.toFixed(2) + '). Traders heavily buying puts on individual stocks — fear/panic sentiment. Dr S: next 10 days SPY historically +0.96%. Contrarian bullish edge active. Crowd is scared, bounce likely.';
  } else if(val <= q25) {
    card.style.background = '#1a0a02';
    card.style.border     = '1px solid #f9731650';
    label.style.color     = '#f97316';
    label.textContent     = val.toFixed(2) + '  BOTTOM QUARTILE';
    sub.style.color       = '#f97316';
    sub.textContent       = 'GREED — NEXT 10 DAYS SPY +0.25%';
    desc.textContent      = 'Today\'s $PCRE = ' + val.toFixed(2) + ' → BOTTOM QUARTILE (≤ ' + q25.toFixed(2) + '). Traders heavily buying calls — greed/complacent sentiment. Dr S: next 10 days SPY historically only +0.25% (subnormal). Crowd complacent, no bullish edge from sentiment here.';
  } else {
    card.style.background = '#0a1a2a';
    card.style.border     = '1px solid #38bdf830';
    label.style.color     = '#38bdf8';
    label.textContent     = val.toFixed(2) + '  MIDDLE';
    sub.style.color       = '#38bdf8';
    sub.textContent       = 'NO EDGE — MIDDLE 50%';
    desc.textContent      = 'Today\'s $PCRE = ' + val.toFixed(2) + ' → MIDDLE zone (' + q25.toFixed(2) + ' – ' + q75.toFixed(2) + '). Sentiment neither extreme greed nor extreme fear. No Dr S edge active from P/C alone. Watch for move into either quartile.';
  }

  // Refresh signal alignment card (uses PCRE value too)
  if(typeof updateAlignmentCard === 'function') updateAlignmentCard();
  // Refresh regime (PCRE feeds into bear-stack modifier)
  if(typeof update === 'function' && window.maData) update();
}

