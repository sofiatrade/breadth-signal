};

function calcSD(vals) {
  const dec = vals.map(v=>v/100);
  const mean = dec.reduce((a,b)=>a+b,0)/dec.length;
  const variance = dec.reduce((s,v)=>s+Math.pow(v-mean,2),0)/dec.length;
  return parseFloat((Math.sqrt(variance)*10).toFixed(2));
}

function sdColor(sd) {
  if(sd>=2.0) return {label:"DANGER",  color:"#ef4444", bg:"#1a0404", desc:"DANGER — Sectors sharply diverging. Reduce longs. Stop buying dips. Consider shorts."};
  if(sd>=1.5) return {label:"WARNING", color:"#f97316", bg:"#1a0a02", desc:"WARNING — Hidden weakness. Reduce size. Tighten stops. Only strongest sectors."};
  if(sd>=1.0) return {label:"CAUTION", color:"#eab308", bg:"#1a1402", desc:"CAUTION — Rotation underway. Be selective. Smaller size. Leading sectors only."};
  if(sd>=0.5) return {label:"CAUTION", color:"#eab308", bg:"#1a1402", desc:"CAUTION — Moderate divergence. Still selective. Watch for rotation."};
  return              {label:"CALM",   color:"#22c55e", bg:"#021408", desc:"CALM — Broad participation. Follow momentum. Full size. Buy dips."};
}

function avgPct(vals, tickers) {
  return tickers.reduce((s,t)=>{ const i=SECTORS.indexOf(t); return s+(i>=0?vals[i]:0); },0)/tickers.length;
}

function detectRegime(maData) {
  const sd3   = maData.find(x=>x.ma===3).sd;
  const sd5   = maData.find(x=>x.ma===5).sd;
  const sd20  = maData.find(x=>x.ma===20).sd;
  const sd50  = maData.find(x=>x.ma===50).sd;
  const sd100 = maData.find(x=>x.ma===100).sd;
  const sd200 = maData.find(x=>x.ma===200).sd;
  const vals20 = maData.find(x=>x.ma===20).vals;
  const vals5  = maData.find(x=>x.ma===5).vals;

  const offAvg5   = avgPct(vals5,  OFFENSE);
  const offAvg20  = avgPct(vals20, OFFENSE);
  const vals50    = maData.find(x=>x.ma===50).vals;
  const vals200   = maData.find(x=>x.ma===200).vals;
  const offAvg50  = avgPct(vals50,  OFFENSE);
  const defAvg50  = avgPct(vals50,  DEFENSE);
  const offAvg200 = avgPct(vals200, OFFENSE);
  const defAvg200 = avgPct(vals200, DEFENSE);

  const chips = [
    {label:`3D σ${sd3.toFixed(1)}`,    ...sdColor(sd3)},
    {label:`5D σ${sd5.toFixed(1)}`,    ...sdColor(sd5)},
    {label:`20D σ${sd20.toFixed(1)}`,  ...sdColor(sd20)},
    {label:`50D σ${sd50.toFixed(1)}`,  ...sdColor(sd50)},
    {label:`200D σ${sd200.toFixed(1)}`,...sdColor(sd200)},
  ];

  // OVERBOUGHT — σ very low short term + offense maxed out
  if(sd3 < 0.5 && sd5 < 0.5 && offAvg5 > 75) {
    return { color:"#f97316", bg:"#1a0a02",
      regime:"OVERBOUGHT", sub:"Do not chase. Take profits.",
      desc:"Everyone in the same trade. Participation maxed out — no new buyers left. σ very low short term means sectors all moving together. Large players likely selling into strength.",
      chips,
      rules:[
        {if:"Opens strong + breadth stalls",   then:"TAKE PROFITS",    color:"#f97316"},
        {if:"Opens weak + selling accelerates", then:"DO NOT BUY",     color:"#ef4444"},
        {if:"Opens weak + lows hold",           then:"WAIT — no edge", color:"#eab308"},
      ],
      note:"σ very low = everyone crowded into same trade. Price not moving higher despite buyers = large players selling into strength. Bulls get trapped. Do not size up here."
    };
  }

  // MOMENTUM — all timeframes healthy, broad participation
  if(sd200 < 0.8 && sd100 < 1.0 && sd20 < 1.5 && sd5 < 1.5 && offAvg20 > 60) {
    return { color:"#22c55e", bg:"#021408",
      regime:"MOMENTUM", sub:"Follow strength. Full size.",
      desc:"σ low across all timeframes. Sectors moving together. Offense above 60% on 20D. Broad participation confirmed. Breakouts extend and continuation works.",
      chips,
      rules:[
        {if:"Opens strong + breadth expands",  then:"CONTINUATION", color:"#22c55e"},
        {if:"Opens weak + lows do NOT expand", then:"BUY THE DIP",  color:"#38bdf8"},
        {if:"Opens weak + lows expand",        then:"SMALL SHORT",  color:"#eab308"},
      ],
      note:"In trending markets each unit of volume gives more price movement. Enter on strength — moves extend. Size up but respect volatility."
    };
  }

  // OVERSOLD — cross-sector avg 50D MA below 25% — Dr S fixed quartile threshold
  const avg50now = window.breadth50Data?.current ?? null;
  const weakMarketAlso = (sd3 >= 2.0 || sd5 >= 2.0) && sd20 >= 1.5;
  if(avg50now !== null && avg50now <= 25) {
    const warningText = weakMarketAlso
      ? "WARNING — WEAK MARKET also active. Oversold in downtrend. Bounces fail more often. Reduce size. Wait for lows to stop expanding before buying."
      : "In bull market correction — high probability bounce setup. Dr S edge: next 5 days ~4x normal returns. Buy weakness when lows stop expanding.";
    return { color:"#22c55e", bg:"#021408",
      regime:"OVERSOLD", sub:"Buy weakness. Fade panic.",
      desc:"Cross-sector avg % above 50D MA below 25%. Dr Steenbarger bottom quartile — bounce edge active. " + warningText,
      chips,
      rules:[
        {if:"Opens weak + lows do NOT expand",    then:"HIGH PROB REVERSAL", color:"#22c55e"},
        {if:"Opens weak + lows still expanding",   then:"WAIT — more selling", color:"#eab308"},
        {if:"Opens strong + breadth expands",      then:"CONFIRM LONG",       color:"#38bdf8"},
      ],
      note:weakMarketAlso
        ? "Oversold in downtrend — Dr S warning: weakness can beget further weakness before bounce. Reduce size. Shorter holds. Wait for lows to stop expanding."
        : "Oversold in healthy market — Dr S edge active. Next 5 days historically ~4x normal. Buy dips when lows stop expanding. Scale in carefully."
    };
  }

  // BULL MARKET — 50D breadth quartile in upper half (>50%)
  // Dr Steenbarger: strong 50D breadth → pullbacks on 50-day horizon are buyable
  // Stacking modifier: count bear signals from PCRE, RSI, BB Breadth
  // 3+ bears = OVERBOUGHT warning on top of bull structure
  // 2 bears  = EXTENDED caution
  // High σ  = ROTATION (volatile rotation inside bull)
  // Clean   = pure BULL MARKET
  const b50nowBull = window.breadth50Data?.current ?? null;
  if(b50nowBull !== null && b50nowBull > 50) {
    const topQ = b50nowBull >= 75;
    const sigmaHot = (sd3 >= 2.0 || sd5 >= 2.0) && sd20 >= 1.5;

    // Count bear signals stacking against the bull structure
    let bullRegBears = 0;
    const bearList = [];
    const pcreValBR = window.pcreValue ?? null;
    const pcQ25BR   = window.pcreQ25 ?? 0.53;
    if(pcreValBR !== null && pcreValBR <= pcQ25BR) {
      bullRegBears++;
      bearList.push('PCRE greed');
    }
    const rsiValBR = window.rsiValue ?? null;
    if(rsiValBR !== null && rsiValBR >= 70) {
      bullRegBears++;
      bearList.push('RSI overbought');
    }
    const bbValBR = window.bbData?.current ?? null;
    const bbQ75BR = window.bbData?.q75 ?? null;
    if(bbValBR !== null && bbQ75BR !== null && bbValBR >= bbQ75BR) {
      bullRegBears++;
      bearList.push('BB breadth highest Q');
    }
    const bearSummary = bearList.length ? bearList.join(' + ') : 'none';

    // Determine label priority: topQ > 3 bears > 2 bears > sigmaHot > clean
    let regimeLabel, regimeSub, regimeDesc, regimeColor, regimeBg;
    if(topQ) {
      regimeLabel = "BULL MARKET — OVERBOUGHT";
      regimeSub = "Do not chase. Pullbacks on 50D horizon still buyable.";
      regimeDesc = "50D breadth in top quartile (>75%). Dr Steenbarger: next 5 day SPY returns only +0.11% — short term overbought, do not chase. BUT 50-day returns remain favorable after strong breadth. Pullbacks are meant to be bought. Think like an investor as well as a trader.";
      regimeColor = "#f97316"; regimeBg = "#1a0a02";
    } else if(bullRegBears >= 3) {
      regimeLabel = "BULL MARKET — OVERBOUGHT";
      regimeSub = "Bull structure intact BUT " + bullRegBears + " bear signals stacked. Do not chase. Wait for pullback.";
      regimeDesc = "50D breadth in upper half (" + b50nowBull + "%) = bull structure intact. BUT " + bullRegBears + " bear signals stacked (" + bearSummary + "). Market extended short-term. Dr Steenbarger stacking principle: same-direction stack = high conviction setup — here pointing to overbought. Do not chase longs. Wait for pullback before entering. Bull regime still valid on 50-day horizon.";
      regimeColor = "#ef4444"; regimeBg = "#1a0408";
    } else if(bullRegBears >= 2) {
      regimeLabel = "BULL MARKET — EXTENDED";
      regimeSub = "Bull structure intact but " + bullRegBears + " bear signals stacked. Caution.";
      regimeDesc = "50D breadth in upper half (" + b50nowBull + "%) = bull structure intact. " + bullRegBears + " bear signals stacked (" + bearSummary + "). Moderate overbought warning. Size down on longs. Watch for signs of pullback.";
      regimeColor = "#f97316"; regimeBg = "#1a0a02";
    } else if(sigmaHot) {
      regimeLabel = "BULL MARKET — ROTATION";
      regimeSub = "Volatile rotation inside bull trend. Buy pullbacks.";
      regimeDesc = "50D breadth in upper half (" + b50nowBull + "%). σ elevated short and medium term — but this is VOLATILE ROTATION inside a bull structure, not a bear market. Dr Steenbarger: after strong 50D breadth, pullbacks are meant to be bought. Traders who bail out miss the bounce. Dual trader/investor mindset required.";
      regimeColor = "#22c55e"; regimeBg = "#021408";
    } else {
      regimeLabel = "BULL MARKET";
      regimeSub = "Buy pullbacks. Follow strength.";
      regimeDesc = "50D breadth in upper half (" + b50nowBull + "%). Dr Steenbarger healthy zone. σ calm, participation intact. Pullbacks on 50-day horizon are buyable. Follow strength but do not chase into top quartile.";
      regimeColor = "#22c55e"; regimeBg = "#021408";
    }

    return { color: regimeColor, bg: regimeBg,
      regime: regimeLabel, sub: regimeSub,
      desc: regimeDesc,
      chips,
      rules: (topQ || bullRegBears >= 2) ? [
        {if:"Opens strong + breadth stalls",       then:"TAKE PROFITS — extended",  color:"#f97316"},
        {if:"Opens weak + lows do NOT expand",     then:"BUY THE DIP — investor",   color:"#22c55e"},
        {if:"Opens weak + lows expand",            then:"WAIT — let it wash out",   color:"#eab308"},
      ] : [
        {if:"Opens weak + lows do NOT expand",     then:"BUY THE DIP",               color:"#22c55e"},
        {if:"Opens strong + breadth expands",      then:"TRADE CONTINUATION",        color:"#22c55e"},
        {if:"Opens weak + lows expand",            then:"WAIT — do not short trend", color:"#eab308"},
      ],
      note: (bullRegBears >= 2)
        ? "Dr Steenbarger stacking: bull structure (50D > 50%) but " + bullRegBears + " contrarian bear signals (" + bearSummary + "). Same-direction stack = high conviction. Today that high conviction points to overbought. Investor mindset: 50-day pullbacks still buyable. Trader mindset: do not chase here, wait for weakness."
        : (topQ
          ? "Dr Steenbarger dual mindset: short-term pullback likely (next 5 days subnormal +0.11%) but 50-day horizon favors buying weakness. Do not chase top quartile. Wait for dip, then buy as an investor would."
          : (sigmaHot
            ? "Dr Steenbarger: strong 50D breadth + high σ = rotation inside bull, not bear. Traders bail on short-term weakness and miss the bounce. Think dually — trade the volatility intraday, but do not short the trend. Pullbacks are meant to be bought."
            : "Dr Steenbarger bull regime: pullbacks on 50-day horizon are buyable. Follow leading sectors. Size up on dips when lows stop expanding. Do not fade strength."))
    };
  }

  // WEAK MARKET — σ high short and medium term AND 50D breadth broken
  if((sd3 >= 2.0 || sd5 >= 2.0) && sd20 >= 1.5) {
    const b50now = window.breadth50Data?.current ?? null;
    const b5now  = window.breadth5Data?.current  ?? null;
    const bbNow  = window.bbData?.current         ?? null;
    const bbQ25  = window.bbData?.q25             ?? null;
    const exhaustionWarning = (
      b50now !== null && b50now <= 28 &&
      b5now  !== null && b5now  <= 28 &&
      bbNow  !== null && bbQ25  !== null && bbNow <= bbQ25
    );
    const regimeLabel = exhaustionWarning ? "WEAK MARKET — OVERSOLD" : "WEAK MARKET";
    const regimeSub   = exhaustionWarning ? "Bounce risk extreme. Suspend momentum short." : "Short side bias. Do not buy dips.";
    const regimeDesc  = exhaustionWarning
      ? "σ high short and medium term — WEAK MARKET structural conditions intact. BUT 50D + 5D + BB all at exhaustion levels simultaneously. Oversold within downtrend. Bounces fail more often but bounce risk is extreme. Do not add shorts. Wait for ADD reversal confirmation."
      : "σ high short and medium term. Sectors sharply diverging for weeks. Breakouts fail. Breakdowns extend. Short side has edge today.";
    return { color:"#ef4444", bg:"#1a0408",
      regime: regimeLabel, sub: regimeSub,
      desc: regimeDesc,
      chips,
      exhaustionWarning,
      rules:[
        {if:"Opens weak + new lows expand",          then:"MOMENTUM SHORT",           color:"#ef4444"},
        {if:"Opens strong + most sectors still red", then:"SELL THE BOUNCE",          color:"#f97316"},
        {if:"Opens weak + new lows do NOT expand",   then:"FAILED BREAKDOWN — scalp", color:"#38bdf8"},
      ],
      note:"σ high = sectors diverging for weeks. Breakouts fail. Breakdowns extend. Look for VWAP reclaim shorts in weak sectors. Reduce size. Intraday only."
    };
  }

  // ROTATION — default mixed signals
  return { color:"#38bdf8", bg:"#0a1a2a",
    regime:"CHOPPY", sub:"Be selective. Lead sectors only.",
    desc:"Mixed σ signals. Some timeframes healthy, some not. Neither buyers nor sellers dominant. Breakouts work in leading sectors only — not broad market.",
    chips,
    rules:[
      {if:"Opens strong + breadth expands",  then:"SMALL LONG — quick",  color:"#22c55e"},
      {if:"Opens weak + lows expand",        then:"SMALL SHORT — quick", color:"#ef4444"},
      {if:"Opens weak + lows hold",          then:"FADE — scalp only",   color:"#38bdf8"},
    ],
    note:"In rotational markets — moves reverse not extend. Fade buying and selling that is drying up. Smaller size, shorter holds, quicker exits. Follow leading sectors only."
  };
}

