// Compute XLE-vs-SPY rotation signal per Dr S Jan 16 2026 post.
// XLE_20D - SPY_20D_proxy (where SPY proxy = avg of all 11 sector 20D readings)
// When the spread is in the TOP HALF of its distribution since 2020 → subnormal SPY forward returns.
// Top extreme → negative returns next 3-5 days.
// Uses full history captured in parseCSV history20 arrays.
function computeXleRotation(sectorResults) {
  const xleResult = sectorResults.find(r => r?.ticker === 'XLE');
  if(!xleResult?.history20?.length) return null;

  // Build a date-keyed map of SPY-proxy values (avg of all sector 20D readings per date)
  // Only include dates where we have at least 8 of the 11 sectors to keep signal clean
  const dateMap = {};  // date -> {sum, count}
  for(const r of sectorResults) {
    if(!r?.history20) continue;
    for(const {date, val} of r.history20) {
      if(!dateMap[date]) dateMap[date] = { sum: 0, count: 0 };
      dateMap[date].sum += val;
      dateMap[date].count += 1;
    }
  }

  // Compute spread history: XLE_20D - SPY_proxy_20D, filtered to 2020+
  const spreadHistory = [];
  for(const {date, val: xleVal} of xleResult.history20) {
    if(date < '2020-01-01') continue;  // Dr S rule starts from 2020
    const agg = dateMap[date];
    if(!agg || agg.count < 8) continue;
    const spyProxy = agg.sum / agg.count;
    spreadHistory.push({ date, spread: xleVal - spyProxy, xleVal, spyProxy });
  }

  if(spreadHistory.length < 50) return null;

  // Current reading = last row
  const last = spreadHistory[spreadHistory.length - 1];
  const allSpreads = spreadHistory.map(x => x.spread).sort((a,b) => a - b);
  const n = allSpreads.length;
  const q25 = allSpreads[Math.floor(n * 0.25)];
  const q50 = allSpreads[Math.floor(n * 0.50)];
  const q75 = allSpreads[Math.floor(n * 0.75)];
  const q90 = allSpreads[Math.floor(n * 0.90)];

  return {
    current: Math.round(last.spread * 10) / 10,
    xleCurrent: Math.round(last.xleVal * 10) / 10,
    spyCurrent: Math.round(last.spyProxy * 10) / 10,
    q25: Math.round(q25 * 10) / 10,
    q50: Math.round(q50 * 10) / 10,
    q75: Math.round(q75 * 10) / 10,
    q90: Math.round(q90 * 10) / 10,
    n,
    date: last.date
  };
}

