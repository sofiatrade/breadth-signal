<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sector Breadth Divergence</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #060810; color: #ffffff; font-family: 'Courier New', monospace; font-size: 13px; padding: 16px 20px; min-height: 100vh; -webkit-font-smoothing: antialiased; }
.header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1a2535; padding-bottom: 12px; margin-bottom: 16px; }
.header h1 { font-family: Impact, sans-serif; font-size: 24px; color: #ffffff; letter-spacing: 2px; }
.grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; align-items: start; }
.card { background: #0a0f1a; border: 1px solid #1a2535; border-radius: 8px; padding: 14px; }
.card-title { font-size: 10px; color: #ffffff; letter-spacing: 2px; margin-bottom: 12px; font-weight: 700; }
.signal-box { border-radius: 8px; padding: 16px; margin-bottom: 14px; }
.signal-big { font-family: Impact, sans-serif; font-size: 56px; line-height: 1; }
.signal-label { font-size: 14px; font-weight: 700; margin-top: 6px; letter-spacing: 2px; }
.ma-row { display: flex; justify-content: space-between; align-items: center; padding: 9px 8px; margin-bottom: 4px; border-radius: 5px; cursor: pointer; border: 1px solid transparent; transition: all .15s; }
.ma-row:hover { background: #1a2535; }
.ma-row.active { background: #1a2535; }
.ma-name { color: #ffffff; font-size: 12px; width: 42px; font-weight: 700; }
.ma-sd { font-size: 20px; font-weight: 700; }
.ma-badge { font-size: 9px; padding: 3px 7px; border-radius: 2px; font-weight: 700; }
.divider { border-top: 1px solid #1a2535; margin: 12px 0; }
.level-row { display: flex; justify-content: space-between; margin-bottom: 7px; font-size: 11px; }
.regime-box { border-radius: 6px; padding: 10px 12px; margin-bottom: 8px; border: 1px solid; }
.regime-name { font-size: 11px; font-weight: 700; letter-spacing: 1px; margin-bottom: 3px; }
.regime-cond { font-size: 11px; color: #ffffff; margin-bottom: 4px; line-height: 1.5; }
.regime-text { font-size: 11px; line-height: 1.6; color: #ffffff; }
.scenario { font-size: 10px; margin-top: 5px; padding-top: 5px; border-top: 1px solid #ffffff15; line-height: 1.8; color: #ffffff; }
.scenario span { font-weight: 700; }
.combined-box { border-radius: 8px; padding: 14px; margin-bottom: 14px; border: 2px solid; }
.combined-title { font-size: 10px; letter-spacing: 2px; font-weight: 700; margin-bottom: 10px; color: #ffffff; }
.combined-regime { font-family: Impact, sans-serif; font-size: 26px; margin-bottom: 6px; letter-spacing: 1px; }
.combined-sub { font-size: 11px; font-weight: 700; margin-bottom: 8px; letter-spacing: 1px; }
.combined-desc { font-size: 11px; line-height: 1.8; color: #ffffff; margin-bottom: 12px; }
.tf-bar { display: flex; gap: 4px; margin-bottom: 12px; flex-wrap: wrap; }
.tf-chip { font-size: 9px; padding: 3px 8px; border-radius: 2px; font-weight: 700; }
.intraday-title { font-size: 10px; letter-spacing: 2px; color: #ffffff; margin-bottom: 8px; font-weight: 700; border-top: 1px solid #ffffff20; padding-top: 10px; }
.rule-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 7px; font-size: 10px; gap: 8px; }
.rule-if { color: #ffffff; flex: 1; line-height: 1.6; font-size: 11px; }
.rule-then { font-size: 9px; padding: 2px 7px; border-radius: 2px; font-weight: 700; white-space: nowrap; }
.dr-note { font-size: 10px; color: #ffffff; margin-top: 10px; padding-top: 8px; border-top: 1px solid #ffffff15; line-height: 1.7; font-style: italic; }
.group-label { font-size: 9px; letter-spacing: 2px; font-weight: 700; padding: 4px 0 6px 0; margin-top: 8px; border-bottom: 1px solid #1a2535; margin-bottom: 8px; }
.sector-row { margin-bottom: 10px; }
.sector-top { display: flex; justify-content: space-between; margin-bottom: 2px; align-items: flex-start; }
.sector-val { font-size: 11px; font-weight: 700; }
.bar-bg { height: 5px; background: #1a2535; border-radius: 2px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 2px; }
.interp-label { font-family: Impact, sans-serif; font-size: 40px; margin-bottom: 6px; letter-spacing: 1px; }
.interp-sd { font-family: Impact, sans-serif; font-size: 22px; margin-bottom: 10px; }
.interp-desc { font-size: 12px; line-height: 2.0; color: #ffffff; }
.footer { text-align: center; margin-top: 14px; font-size: 9px; color: #4a6a8a; letter-spacing: 2px; }
</style>
</head>
<body>

<div class="header">
  <h1>SECTOR BREADTH DIVERGENCE</h1>
  <div style="text-align:right;font-size:10px;color:#aaccee">
    <div>DATA AS OF 2026-03-12</div>
    <div style="margin-top:3px;color:#f97316">SIMULATED PREVIEW</div>
  </div>
</div>

<div class="grid">

  <!-- LEFT -->
  <div>
    <div class="signal-box" id="signalBox">
      <div class="card-title">TODAY · 20D MA</div>
      <div class="signal-big" id="signalBig">σ –</div>
      <div class="signal-label" id="signalLabel">–</div>
    </div>

    <div class="card">
      <div class="card-title">STD DEVIATION ALL TIMEFRAMES</div>
      <div id="maList"></div>

      <div class="divider"></div>
      <div class="card-title">REFERENCE LEVELS</div>
      <div class="level-row"><span style="color:#ef4444;font-weight:700">σ &gt; 2.0</span><span style="color:#ef4444;font-weight:700">DANGER</span></div>
      <div class="level-row"><span style="color:#f97316;font-weight:700">σ &gt; 1.5</span><span style="color:#f97316;font-weight:700">WARNING</span></div>
      <div class="level-row"><span style="color:#eab308;font-weight:700">σ &gt; 1.0</span><span style="color:#eab308;font-weight:700">CAUTION</span></div>
      <div class="level-row"><span style="color:#22c55e;font-weight:700">σ &lt; 0.5</span><span style="color:#22c55e;font-weight:700">CALM</span></div>

      <div class="divider"></div>
      <div class="card-title">YOUR 4 REGIMES — DR STEENBARGER METHOD</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">

      <!-- TRENDING -->
      <div class="regime-box" style="background:#02140820;border-color:#22c55e40">
        <div class="regime-name" style="color:#22c55e">● MOMENTUM</div>
        <div class="regime-cond" style="color:#22c55e;font-weight:700;margin-bottom:4px">Follow strength. Full size.</div>
        <div class="regime-cond">σ low all timeframes. Offense above 60% on 20D. Sectors moving together. Breakouts extend and work.</div>
        <div class="scenario">
          Opens strong + breadth expands → <span style="color:#22c55e">TRADE CONTINUATION</span><br>
          Opens weak + lows do NOT expand → <span style="color:#38bdf8">BUY THE DIP — bull intact</span><br>
          Opens weak + lows expand → <span style="color:#eab308">SMALL SHORT — expect bounce</span>
        </div>
      </div>

      <!-- CROWDED -->
      <div class="regime-box" style="background:#1a0a0220;border-color:#f9731640">
        <div class="regime-name" style="color:#f97316">● OVERBOUGHT</div>
        <div class="regime-cond" style="color:#f97316;font-weight:700;margin-bottom:4px">Do not chase. Take profits.</div>
        <div class="regime-cond">σ very low short term. Offense above 75% on 5D. Everyone in same trade. Participation maxed out — no new buyers left.</div>
        <div class="scenario">
          Opens strong + breadth stalls → <span style="color:#f97316">TAKE PROFITS — trap forming</span><br>
          Opens weak + selling starts → <span style="color:#ef4444">DO NOT BUY — large players exiting</span><br>
          Opens weak + lows hold → <span style="color:#eab308">WAIT — no edge yet</span>
        </div>
      </div>

      <!-- ROTATION -->
      <div class="regime-box" style="background:#0a0a0a20;border-color:#38bdf840">
        <div class="regime-name" style="color:#38bdf8">● CHOPPY</div>
        <div class="regime-cond" style="color:#38bdf8;font-weight:700;margin-bottom:4px">Be selective. Lead sectors only.</div>
        <div class="regime-cond">Mixed σ signals. Some timeframes healthy, some not. Neither buyers nor sellers dominant. Breakouts work in leaders only.</div>
        <div class="scenario">
          Opens strong + breadth expands → <span style="color:#22c55e">SMALL LONG — quick profits</span><br>
          Opens weak + lows expand → <span style="color:#ef4444">SMALL SHORT — quick profits</span><br>
          Opens weak + lows hold → <span style="color:#38bdf8">FADE — scalp only</span>
        </div>
      </div>

      <!-- WEAK MARKET -->
      <div class="regime-box" style="background:#1a040820;border-color:#ef444440">
        <div class="regime-name" style="color:#ef4444">● WEAK MARKET</div>
        <div class="regime-cond" style="color:#ef4444;font-weight:700;margin-bottom:4px">Reduce size. Short side bias.</div>
        <div class="regime-cond">σ high short and medium term. Sectors sharply diverging for weeks. Breakouts fail. Breakdowns extend.</div>
        <div class="scenario">
          Opens weak + new lows expand → <span style="color:#ef4444">MOMENTUM SHORT</span><br>
          Opens strong + most sectors still red → <span style="color:#f97316">SELL THE BOUNCE</span><br>
          Opens weak + lows do NOT expand → <span style="color:#38bdf8">FAILED BREAKDOWN — scalp only</span>
        </div>
      </div>

      <!-- OVERSOLD -->
      <div class="regime-box" style="background:#02140820;border-color:#22c55e40;grid-column:1/-1">
        <div class="regime-name" style="color:#22c55e">● OVERSOLD</div>
        <div class="regime-cond" style="color:#22c55e;font-weight:700;margin-bottom:4px">Buy weakness. Fade panic.</div>
        <div class="regime-cond">Cross-sector avg % above 50D MA below 25%. Stocks stretched too far down. Bounce edge active per Dr Steenbarger — next 5 days historically ~4x normal returns.</div>
        <div class="scenario">
          Opens weak + lows do NOT expand → <span style="color:#22c55e">HIGH PROB REVERSAL — buy now</span><br>
          Opens weak + lows still expanding → <span style="color:#eab308">WAIT — not yet, more selling coming</span><br>
          Opens strong + breadth expands → <span style="color:#38bdf8">CONFIRM LONG — add size</span><br>
          <span style="color:#ef4444;font-weight:700">WARNING — if WEAK MARKET also active: oversold in downtrend. Bounces fail more often. Reduce size. Wait for lows to stop expanding first.</span>
        </div>
      </div>

      </div>

      <div class="divider"></div>
      <div style="font-size:9px;color:#aaccee;line-height:1.8;font-style:italic">
        "In volatile markets — size DOWN. Volatility is already sizing up your positions. The faster the market moves, the slower you should make yourself to adapt."
      </div>

    </div>
  </div>

  <!-- MIDDLE -->
  <div>
    <div class="card" style="margin-bottom:14px">
      <div class="card-title">
        σ HISTORY &nbsp;
        <span style="color:#00ffff">— 3D</span> &nbsp;
        <span style="color:#7b2fff">— 20D</span> &nbsp;
        <span style="color:#1e90ff">— 50D</span> &nbsp;
        <span style="color:#ff0055">— 200D</span>
      </div>
      <canvas id="histChart" height="160"></canvas>
    </div>
    <div class="card" style="margin-bottom:14px">
      <div class="card-title" id="barTitle">% STOCKS ABOVE MA — 20D</div>
      <canvas id="barChart" height="160"></canvas>
    </div>
    <div class="card">
      <div class="card-title" id="sectorTitle">SECTORS — 20D</div>
      <div id="sectorList"></div>
    </div>

  </div>

  <!-- RIGHT -->
  <div>
    <div class="combined-box" id="combinedBox">
      <div class="combined-title">TODAY'S REGIME</div>
      <div class="tf-bar" id="tfBar"></div>
      <div class="combined-regime" id="combinedRegime">–</div>
      <div class="combined-sub" id="combinedSub">–</div>
      <div class="combined-desc" id="combinedDesc">–</div>
      <div id="todayStackBox" style="margin-top:10px;padding:8px 10px;border-radius:4px;background:#0a0f1a;border-left:3px solid #6b7a8f;font-size:10px;line-height:1.7;display:none">
        <div style="font-size:9px;color:#6b7a8f;letter-spacing:1px;font-weight:700;margin-bottom:4px">TODAY'S STACK — DR S ALIGNED</div>
        <div id="todayStackLines" style="color:#ffffff;margin-bottom:6px"></div>
        <div id="todayStackAction" style="font-size:10px;font-weight:700;letter-spacing:1px;padding-top:5px;border-top:1px solid #ffffff20"></div>
      </div>
      <div class="intraday-title">INTRADAY RULES — TODAY</div>
      <div class="rule-row">
        <span class="rule-if" id="ruleIf1">–</span>
        <span class="rule-then" id="ruleThen1">–</span>
      </div>
      <div class="rule-row">
        <span class="rule-if" id="ruleIf2">–</span>
        <span class="rule-then" id="ruleThen2">–</span>
      </div>
      <div class="rule-row">
        <span class="rule-if" id="ruleIf3">–</span>
        <span class="rule-then" id="ruleThen3">–</span>
      </div>
      <div class="dr-note" id="drNote">–</div>

      <!-- ROTATION BREADTH — Dr Steenbarger method -->
      <div class="intraday-title">ROTATION BREADTH</div>
      <div id="rotationNumbers" style="font-size:10px;font-weight:700;letter-spacing:1px;margin-bottom:6px;line-height:2.0"></div>
      <div id="rotationFullTable" style="font-size:10px;margin-bottom:8px"></div>
      <div id="rotationSectors" style="font-size:10px;line-height:2.0;margin-bottom:6px"></div>
      <div id="rotationText" style="font-size:11px;color:#aaccee;line-height:1.8"></div>

      <div class="intraday-title" id="alignmentTitle" style="display:none">SIGNAL ALIGNMENT</div>
      <div id="alignmentExplainer" style="font-size:9px;color:#6b7a8f;line-height:1.6;margin-bottom:6px;font-style:italic;display:none">Dr S stacking: (1) same-direction stack = high conviction setup. (2) conflicting stack = wait, no edge.</div>
      <div id="alignmentScore" style="font-size:11px;font-weight:700;margin-bottom:6px;letter-spacing:1px;display:none"></div>
      <div id="alignmentSignals" style="font-size:9px;line-height:1.9;color:#aaccee;display:none"></div>

      <!-- DR STEENBARGER FRAMEWORK — static reference of confirmed edges -->
      <div class="intraday-title" style="margin-top:14px">DR STEENBARGER FRAMEWORK</div>
      <div style="font-size:10px;line-height:1.7;color:#ffffff">

        <div style="margin-bottom:8px;padding:6px 8px;background:#0a1a2a;border-left:3px solid #22c55e;border-radius:2px">
          <div style="font-size:9px;color:#22c55e;letter-spacing:1px;font-weight:700;margin-bottom:2px">50D BREADTH QUARTILE — PRIMARY EDGE</div>
          <div style="color:#aaccee">Top Q &gt;75% → next 5 days +0.11% (subnormal). Do not chase.</div>
          <div style="color:#aaccee">Bottom Q &lt;25% → next 5 days ~4x normal. Bounce edge active.</div>
          <div style="color:#22c55e;margin-top:3px;font-weight:700">Dual mindset: after strong 50D breadth, pullbacks on 50-day horizon are meant to be bought. Traders bail and miss the bounce.</div>
        </div>

        <div style="margin-bottom:8px;padding:6px 8px;background:#0a1a2a;border-left:3px solid #38bdf8;border-radius:2px">
          <div style="font-size:9px;color:#38bdf8;letter-spacing:1px;font-weight:700;margin-bottom:2px">200D BREADTH QUARTILE — STRUCTURE</div>
          <div style="color:#aaccee">Bottom Q &lt;25% → next 10 days SPY +1.32% (strongest long-term bounce).</div>
          <div style="color:#aaccee">Top Q &gt;75% → next 10 days SPY -0.04% (structural overbought).</div>
        </div>

        <div style="margin-bottom:8px;padding:6px 8px;background:#0a1a2a;border-left:3px solid #a78bfa;border-radius:2px">
          <div style="font-size:9px;color:#a78bfa;letter-spacing:1px;font-weight:700;margin-bottom:2px">5D + 100D CONTEXT RULE</div>
          <div style="color:#aaccee">5D low + 100D low → next 10 days +1.00% (max bounce edge).</div>
          <div style="color:#aaccee">5D low + 100D high → next 10 days +0.38% (just a dip).</div>
        </div>

        <div style="margin-bottom:8px;padding:6px 8px;background:#0a1a2a;border-left:3px solid #f97316;border-radius:2px">
          <div style="font-size:9px;color:#f97316;letter-spacing:1px;font-weight:700;margin-bottom:2px">σ DIVERGENCE — REGIME VOLATILITY</div>
          <div style="color:#aaccee">σ &gt;2.0 = DANGER / sectors diverging / breakouts fail.</div>
          <div style="color:#aaccee">σ 1.5–2.0 = WARNING / hidden weakness.</div>
          <div style="color:#aaccee">σ &lt;0.5 = CALM / broad participation / full size.</div>
        </div>

        <div style="padding:6px 8px;background:#1a1402;border-left:3px solid #eab308;border-radius:2px">
          <div style="font-size:9px;color:#eab308;letter-spacing:1px;font-weight:700;margin-bottom:2px">DR S PRINCIPLE — VOLATILITY SIZING</div>
          <div style="color:#ffffff;font-style:italic">"In volatile markets — size DOWN. Volatility is already sizing up your positions. The faster the market moves, the slower you should make yourself to adapt."</div>
        </div>
      </div>
    </div>

    <div class="card" style="margin-bottom:14px" id="interpBox">
      <div class="card-title" id="interpTitle">SIGNAL · CLICK A TIMEFRAME</div>
      <div class="interp-label" id="interpLabel">–</div>
      <div class="interp-sd" id="interpSd"></div>
      <div class="interp-desc" id="interpDesc">Click any MA timeframe on the left.</div>
    </div>

    <!-- 50D BREADTH QUARTILE — Dr Steenbarger method -->
    <div class="card" style="margin-bottom:14px" id="breadth50Card">
      <div class="card-title">50D BREADTH QUARTILE</div>
      <div id="breadth50Label" style="font-family:Impact,sans-serif;font-size:28px;letter-spacing:1px;margin-bottom:4px">–</div>
      <div id="breadth50Sub" style="font-size:11px;font-weight:700;margin-bottom:8px;letter-spacing:1px">–</div>
      <div id="breadth50Desc" style="font-size:10px;line-height:1.8;color:#ffffff">Loading historical data...</div>
    </div>

    <!-- BOLLINGER BAND BREADTH — Dr Steenbarger method -->
    <div class="card" style="margin-bottom:14px" id="bollingerCard">
      <div class="card-title">NYSE BOLLINGER BAND BREADTH</div>
      <div id="bollingerLabel" style="font-family:Impact,sans-serif;font-size:28px;letter-spacing:1px;margin-bottom:4px">–</div>
      <div id="bollingerSub" style="font-size:11px;font-weight:700;margin-bottom:8px;letter-spacing:1px">–</div>
      <div id="bollingerDesc" style="font-size:10px;line-height:1.8;color:#ffffff">Loading...</div>
      <div id="bollingerQuartile" style="font-size:9px;color:#aaccee;margin-top:6px;line-height:1.6;font-style:italic"></div>
    </div>

    <!-- 5D BREADTH QUARTILE — Dr Steenbarger method -->
    <div class="card" style="margin-bottom:14px" id="breadth5Card">
      <div class="card-title">5D BREADTH QUARTILE</div>
      <div id="breadth5Label" style="font-family:Impact,sans-serif;font-size:28px;letter-spacing:1px;margin-bottom:4px">–</div>
      <div id="breadth5Sub" style="font-size:11px;font-weight:700;margin-bottom:8px;letter-spacing:1px">–</div>
      <div id="breadth5Desc" style="font-size:10px;line-height:1.8;color:#ffffff">Loading...</div>
    </div>

    <!-- 100D BREADTH QUARTILE — Dr Steenbarger context rule -->
    <div class="card" style="margin-bottom:14px" id="breadth100Card">
      <div class="card-title">100D BREADTH QUARTILE</div>
      <div id="breadth100Label" style="font-family:Impact,sans-serif;font-size:28px;letter-spacing:1px;margin-bottom:4px">–</div>
      <div id="breadth100Sub" style="font-size:11px;font-weight:700;margin-bottom:8px;letter-spacing:1px">–</div>
      <div id="breadth100Desc" style="font-size:10px;line-height:1.8;color:#ffffff">Loading...</div>
    </div>

    <!-- 200D BREADTH QUARTILE — Dr Steenbarger method -->
    <div class="card" style="margin-bottom:14px" id="breadth200Card">
      <div class="card-title">200D BREADTH QUARTILE</div>
      <div id="breadth200Label" style="font-family:Impact,sans-serif;font-size:28px;letter-spacing:1px;margin-bottom:4px">–</div>
      <div id="breadth200Sub" style="font-size:11px;font-weight:700;margin-bottom:8px;letter-spacing:1px">–</div>
      <div id="breadth200Desc" style="font-size:10px;line-height:1.8;color:#ffffff">Loading...</div>
    </div>

    <!-- PCRE EQUITY PUT/CALL RATIO QUARTILE — Dr Steenbarger sentiment rule -->
    <div class="card" style="margin-bottom:14px" id="pcreCard">
      <div class="card-title">PCRE EQUITY PUT/CALL QUARTILE</div>
      <div id="pcreLabel" style="font-family:Impact,sans-serif;font-size:28px;letter-spacing:1px;margin-bottom:4px">–</div>
      <div id="pcreSub" style="font-size:11px;font-weight:700;margin-bottom:8px;letter-spacing:1px">–</div>
      <div id="pcreDesc" style="font-size:10px;line-height:1.8;color:#ffffff;margin-bottom:10px">–</div>

      <div style="display:flex;gap:6px;align-items:center;margin-bottom:10px">
        <label for="pcreInput" style="font-size:10px;color:#aaccee;letter-spacing:1px;font-weight:700">$PCRE TODAY:</label>
        <input type="number" id="pcreInput" step="0.01" min="0" max="3" value="0.45"
          style="flex:1;background:#0a0f1a;border:1px solid #1a2535;color:#ffffff;padding:4px 8px;font-family:'Space Mono',monospace;font-size:12px;border-radius:3px;outline:none" />
        <button id="pcreBtn" style="background:#38bdf830;border:1px solid #38bdf850;color:#38bdf8;padding:4px 10px;font-size:10px;font-weight:700;letter-spacing:1px;cursor:pointer;border-radius:3px;font-family:'Space Mono',monospace">UPDATE</button>
      </div>

