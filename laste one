    const headers = lines[0].split(',').map(h => h.trim().toUpperCase());
    // Find the CLOSE column — PCRE csv has $PCRE:CLOSE
    const closeIdx = headers.findIndex(h => h.includes('CLOSE'));
    const dateIdx  = headers.findIndex(h => h.includes('DATE'));
    if(closeIdx < 0) return null;
    // Walk backwards to find last non-empty close value (for latest)
    let lastVal = null;
    let lastDate = null;
    for(let i = lines.length - 1; i >= 1; i--) {
      const cols = lines[i].split(',');
      const v = parseFloat(cols[closeIdx]);
      if(!isNaN(v)) {
        lastVal = v;
        lastDate = dateIdx >= 0 ? cols[dateIdx] : null;
        break;
      }
    }
    if(lastVal === null) return null;
    const allVals = lines.slice(1)
      .map(l => parseFloat(l.split(',')[closeIdx]))
      .filter(v => !isNaN(v));
    allVals.sort((a,b) => a - b);
    const q25 = allVals[Math.floor(allVals.length * 0.25)];
    const q75 = allVals[Math.floor(allVals.length * 0.75)];
    return {
      current: Math.round(lastVal*100)/100,
      q25: Math.round(q25*100)/100,
      q75: Math.round(q75*100)/100,
      date: lastDate,
      n: allVals.length
    };
  } catch(e) { return null; }
}

