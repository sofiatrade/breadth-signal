        Watch ADD on TradingView for reversal confirmation.<br>
        If ADD reverses from extreme negative → cover shorts.
      </div>`;
  } else {
    ewEl.style.display = 'none';
  }

  const sorted = SECTORS.map((s,i)=>({name:s,val:d.vals[i],color:d.vals[i]>=60?"#22c55e":d.vals[i]>=40?"#eab308":"#ef4444"})).sort((a,b)=>b.val-a.val);
  if(barChartObj){
    barChartObj.data.labels = sorted.map(s=>s.name);
    barChartObj.data.datasets[0].data = sorted.map(s=>s.val);
    barChartObj.data.datasets[0].backgroundColor = sorted.map(s=>s.color+'cc');
    barChartObj.update();
  }

  // ROTATION BREADTH — Dr Steenbarger method
  // Confirmed strong = above 50% on BOTH 50D AND 200D
  // Confirmed weak = below 50% on BOTH 50D AND 200D
  const vals50r  = maData.find(x=>x.ma===50)?.vals  || [];
  const vals200r = maData.find(x=>x.ma===200)?.vals || [];
  const offAvg50r  = Math.round(avgPct(vals50r,  OFFENSE));
  const defAvg50r  = Math.round(avgPct(vals50r,  DEFENSE));
  const offAvg200r = Math.round(avgPct(vals200r, OFFENSE));
  const defAvg200r = Math.round(avgPct(vals200r, DEFENSE));

  const off50Color  = offAvg50r  >= defAvg50r  ? '#22c55e' : '#ef4444';
  const def50Color  = defAvg50r  >= offAvg50r  ? '#22c55e' : '#ef4444';
  const off200Color = offAvg200r >= defAvg200r ? '#22c55e' : '#ef4444';
  const def200Color = defAvg200r >= offAvg200r ? '#22c55e' : '#ef4444';

  document.getElementById('rotationNumbers').innerHTML =
    `<span style="color:#aaccee">50D &nbsp;</span><span style="color:${off50Color}">Offense ${offAvg50r}%</span> <span style="color:#aaccee">vs</span> <span style="color:${def50Color}">Defense ${defAvg50r}%</span><br>` +
    `<span style="color:#aaccee">200D</span> <span style="color:${off200Color}">Offense ${offAvg200r}%</span> <span style="color:#aaccee">vs</span> <span style="color:${def200Color}">Defense ${defAvg200r}%</span>`;

  // Confirmed strong/weak sectors — Dr S method: above 50% on BOTH timeframes = confirmed
  const confirmedStrong = SECTORS.filter((s,i) => vals50r[i] > 50 && vals200r[i] > 50)
    .map((s,i) => {
      const idx = SECTORS.indexOf(s);
      return `<span style="color:#22c55e;font-weight:700">${s}</span> <span style="color:#aaccee">${Math.round(vals50r[idx])}%/50D ${Math.round(vals200r[idx])}%/200D</span>`;
    });
  const confirmedWeak = SECTORS.filter((s,i) => vals50r[i] < 50 && vals200r[i] < 50)
    .map((s,i) => {
      const idx = SECTORS.indexOf(s);
      return `<span style="color:#ef4444;font-weight:700">${s}</span> <span style="color:#aaccee">${Math.round(vals50r[idx])}%/50D ${Math.round(vals200r[idx])}%/200D</span>`;
    });

  let rotSectorsHtml = '';
  if(confirmedStrong.length) rotSectorsHtml += `<div style="margin-bottom:4px"><span style="color:#22c55e;font-size:8px;letter-spacing:1px;font-weight:700">ROTATING INTO → </span>${confirmedStrong.join(' ')}</div>`;
  if(confirmedWeak.length)   rotSectorsHtml += `<div><span style="color:#ef4444;font-size:8px;letter-spacing:1px;font-weight:700">ROTATING OUT OF → </span>${confirmedWeak.join(' ')}</div>`;
  document.getElementById('rotationSectors').innerHTML = rotSectorsHtml;

  // Full ETF table — all 11 sectors with 50D and 200D, sorted by 200D strength
  const allSectors = SECTORS.map((s,i) => ({
    name: s,
    v50:  Math.round(vals50r[i]),
    v200: Math.round(vals200r[i]),
    isOffense: OFFENSE.includes(s)
  })).sort((a,b) => b.v200 - a.v200);

  const rowColor = (v50, v200) => {
    if(v50 > 50 && v200 > 50) return '#22c55e';  // confirmed strong
    if(v50 < 50 && v200 < 50) return '#ef4444';  // confirmed weak
    return '#eab308';                              // mixed / rotating
  };
  const cellColor = v => v >= 60 ? '#22c55e' : v >= 40 ? '#eab308' : '#ef4444';

  let tableHtml = '<div style="display:grid;grid-template-columns:auto auto auto;gap:2px 10px;align-items:center;padding:6px 8px;background:#0a0f1a;border:1px solid #1a2535;border-radius:3px">';
  tableHtml += '<span style="font-size:8px;color:#6b7a8f;letter-spacing:1px;font-weight:700">ETF</span>';
  tableHtml += '<span style="font-size:8px;color:#6b7a8f;letter-spacing:1px;font-weight:700;text-align:right">50D</span>';
  tableHtml += '<span style="font-size:8px;color:#6b7a8f;letter-spacing:1px;font-weight:700;text-align:right">200D</span>';
  allSectors.forEach(s => {
    const rc = rowColor(s.v50, s.v200);
    tableHtml += `<span style="font-size:11px;font-weight:700;color:${rc}">${s.name}</span>`;
    tableHtml += `<span style="font-size:11px;color:${cellColor(s.v50)};text-align:right;font-variant-numeric:tabular-nums">${s.v50}%</span>`;
    tableHtml += `<span style="font-size:11px;color:${cellColor(s.v200)};text-align:right;font-variant-numeric:tabular-nums">${s.v200}%</span>`;
  });
  tableHtml += '</div>';
  document.getElementById('rotationFullTable').innerHTML = tableHtml;

  // Dynamic text — clean Dr S style, sector names only, no percentage clutter
  const strongSectorNames = SECTORS.filter((s,i) => vals50r[i] > 50 && vals200r[i] > 50)
    .sort((a,b) => vals200r[SECTORS.indexOf(b)] - vals200r[SECTORS.indexOf(a)]);
  const weakSectorNames = SECTORS.filter((s,i) => vals50r[i] < 50 && vals200r[i] < 50)
    .sort((a,b) => vals200r[SECTORS.indexOf(a)] - vals200r[SECTORS.indexOf(b)]);

  const strongList = strongSectorNames.slice(0,3).join(', ') || '—';
  const weakList   = weakSectorNames.slice(0,3).join(', ')   || '—';

  let rotText = '';
  const offLeads50  = offAvg50r  > defAvg50r;
  const offLeads200 = offAvg200r > defAvg200r;

  if(!offLeads50 && !offLeads200) {
    rotText = `Defensiveness is the watchword — institutions shunning ${weakList}, rotating into ${strongList}. Breakouts in growth sectors will fail. Look for VWAP reclaim rejections in ${weakList.split(',')[0].trim()}. Sell the bounce. Do not buy dips in offense.`;
  } else if(offLeads50 && offLeads200) {
    rotText = `Growth sectors leading — ${strongList} confirmed strong on both timeframes. Breakouts extend and work. Buy first pullback in ${strongList.split(',')[0].trim()}. Do not fade strength.`;
  } else if(offLeads50 && !offLeads200) {
    rotText = `Offense leading medium term but losing long term ground — ${weakList.split(',')[0].trim()} deteriorating on 200D. Breakouts may work intraday but fail multi-day. Quick exits. Take profits faster. Watch 200D deterioration as structural warning.`;
  } else {
    rotText = `Early rotation into defense — ${strongList} showing relative strength. Breakouts in ${weakList.split(',')[0].trim()} becoming less reliable. Reduce long exposure. Favor quick scalps over holds.`;
  }
  document.getElementById('rotationText').textContent = rotText;

  // Sync TODAY'S STACK summary inside regime box
  if(typeof updateTodayStack === 'function') updateTodayStack();
}

