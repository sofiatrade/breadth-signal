    } else if(pcre <= pcQ25) {
      bearCount++;
      lines.push({d:'bear', t:'✗ $PCRE ' + pcre.toFixed(2) + ' — BOTTOM Q — greed, next 10d only +0.25%'});
    } else {
      lines.push({d:'neutral', t:'○ $PCRE ' + pcre.toFixed(2) + ' — middle zone, no sentiment edge'});
    }
  }

  // RSI SPY 5-period — Dr S overbought/oversold rule (contrarian)
  if(rsi !== null) {
    if(rsi >= 70) {
      bearCount++;
      lines.push({d:'bear', t:'✗ SPY RSI(5) ' + rsi.toFixed(1) + ' — OVERBOUGHT — extended, mean reversion risk'});
    } else if(rsi <= 30) {
      bullCount++;
      lines.push({d:'bull', t:'✓ SPY RSI(5) ' + rsi.toFixed(1) + ' — OVERSOLD — bounce likely, trapped sellers'});
    } else {
      lines.push({d:'neutral', t:'○ SPY RSI(5) ' + rsi.toFixed(1) + ' — neutral zone, no edge'});
    }
  }

  // XLE vs SPY breadth rotation — Dr S Jan 16 2026 rule
  const xleRot = window.xleRotation;
  if(xleRot) {
    const sign = xleRot.current >= 0 ? '+' : '';
    if(xleRot.current >= xleRot.q90) {
      bearCount++;
      lines.push({d:'bear', t:'✗ XLE vs SPY ' + sign + xleRot.current.toFixed(1) + ' — EXTREME energy lead → SPY negative next 3-5d'});
    } else if(xleRot.current >= xleRot.q50) {
      bearCount++;
      lines.push({d:'bear', t:'✗ XLE vs SPY ' + sign + xleRot.current.toFixed(1) + ' — energy leading → SPY subnormal forward'});
    } else {
      lines.push({d:'neutral', t:'○ XLE vs SPY ' + sign + xleRot.current.toFixed(1) + ' — no rotation warning'});
    }
  }

  title.style.display = 'block';
  score.style.display = 'block';
  sigs.style.display  = 'block';
  const explainer = document.getElementById('alignmentExplainer');
  if(explainer) explainer.style.display = 'block';

  // Dr S stacking verdict
  let scoreText, scoreColor;
  if(bullCount >= 3 && bearCount === 0) {
    scoreColor = '#22c55e';
    scoreText = bullCount + ' BULL SIGNALS STACKED — HIGH CONVICTION REVERSAL LONG';
  } else if(bearCount >= 3 && bullCount === 0) {
    scoreColor = '#ef4444';
    scoreText = bearCount + ' BEAR SIGNALS STACKED — HIGH CONVICTION DO NOT CHASE';
  } else if(bullCount >= 2 && bearCount === 0) {
    scoreColor = '#22c55e';
    scoreText = bullCount + ' BULL SIGNALS — MODERATE LONG EDGE';
  } else if(bearCount >= 2 && bullCount === 0) {
    scoreColor = '#f97316';
    scoreText = bearCount + ' BEAR SIGNALS — MODERATE EXTENDED WARNING';
  } else if(bullCount > 0 && bearCount > 0) {
    scoreColor = '#eab308';
    scoreText = 'CONFLICTING — ' + bullCount + ' BULL / ' + bearCount + ' BEAR — NO EDGE, WAIT';
  } else if(bullCount === 1) {
    scoreColor = '#ffffff';
    scoreText = '1 BULL SIGNAL — WAIT FOR CONFIRMATION';
  } else if(bearCount === 1) {
    scoreColor = '#ffffff';
    scoreText = '1 BEAR SIGNAL — CAUTION BUT NOT DECISIVE';
  } else {
    scoreColor = '#ffffff';
    scoreText = 'NO SIGNALS ACTIVE — WAIT';
  }
  score.style.color = scoreColor;
  score.textContent = scoreText;

  sigs.innerHTML = lines.map(l => {
    const color = l.d === 'bull' ? '#22c55e' : l.d === 'bear' ? '#ef4444' : '#aaccee';
    return `<div style="color:${color}">${l.t}</div>`;
  }).join('');

  // Sync the regime-box TODAY'S STACK summary
  if(typeof updateTodayStack === 'function') updateTodayStack();
}

// ── P/C EQUITY RATIO QUARTILE — Dr Steenbarger sentiment rule ──
// Data: 2514 obs (2016-2026). Q25=0.53, Q75=0.68. Mean 0.61.
// Bottom Q (<=0.53) = greed/complacent → next 10d SPY +0.25% subnormal
// Top Q    (>=0.68) = fear/panic       → next 10d SPY +0.96% edge active
window.pcreQ25 = 0.53;
window.pcreQ75 = 0.68;
window.pcreValue = 0.45;

update();

(async () => {
  const realData = await loadRealData();
  if(realData) {
    maData = realData;
    update();
  }
})();

// Auto-fetch at US market open (09:32 ET) and every 15 min after
(function scheduleAutoFetch() {
  async function autoRefresh() {
    const realData = await loadRealData();
    if(realData) { maData = realData; update(); }
  }

  function msUntilNext() {
    const now = new Date();
    const isDST = (() => {
      const jan = new Date(now.getFullYear(), 0, 1).getTimezoneOffset();
      const jul = new Date(now.getFullYear(), 6, 1).getTimezoneOffset();
      return now.getTimezoneOffset() < Math.max(jan, jul);
    })();
    const etNow = new Date(now.getTime() + (now.getTimezoneOffset() + (isDST ? -4 : -5) * 60) * 60000);
    const h = etNow.getHours(), m = etNow.getMinutes();
    const totalMin = h * 60 + m;
    const openMin  = 9 * 60 + 32;
    const closeMin = 16 * 60;
    if(totalMin < openMin || totalMin >= closeMin) return 60000;
    const sinceOpen = totalMin - openMin;
    const msIntoInterval = ((sinceOpen % 15) * 60 + etNow.getSeconds()) * 1000 + etNow.getMilliseconds();
    return 15 * 60 * 1000 - msIntoInterval;
  }

  function tick() {
    const ms = msUntilNext();
    setTimeout(async () => {
      const now = new Date();
      const isDST = (() => {
        const jan = new Date(now.getFullYear(), 0, 1).getTimezoneOffset();
        const jul = new Date(now.getFullYear(), 6, 1).getTimezoneOffset();
        return now.getTimezoneOffset() < Math.max(jan, jul);
      })();
      const etNow = new Date(now.getTime() + (now.getTimezoneOffset() + (isDST ? -4 : -5) * 60) * 60000);
      const h = etNow.getHours(), m = etNow.getMinutes();
      const totalMin = h * 60 + m;
      if(totalMin >= 9 * 60 + 32 && totalMin < 16 * 60) {
        await autoRefresh();
      }
      tick();
    }, ms);
  }

  tick();
})();
