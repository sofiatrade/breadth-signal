  if(typeof updateAlignmentCard === 'function') updateAlignmentCard();
}

// ── TODAY'S STACK — compact live summary inside regime box ─────
// Shows 2-3 lines: active signals with Dr S context + 1 action line.
// Appears only when there's at least one meaningful signal to report.
function updateTodayStack() {
  const box      = document.getElementById('todayStackBox');
  const linesEl  = document.getElementById('todayStackLines');
  const actionEl = document.getElementById('todayStackAction');
  if(!box || !linesEl || !actionEl) return;

  const b50  = window.breadth50Data?.current ?? null;
  const b200 = window.breadth200Data?.current ?? null;
  const bb   = window.bbData?.current ?? null;
  const bbQ25= window.bbData?.q25 ?? null;
  const bbQ75= window.bbData?.q75 ?? null;
  const pcre = window.pcreValue ?? null;
  const pcQ25= window.pcreQ25 ?? 0.53;
  const pcQ75= window.pcreQ75 ?? 0.68;
  const rsi  = window.rsiValue ?? null;
  const sd20 = window.maData?.find(x=>x.ma===20)?.sd ?? null;

  const lines = [];
  let bulls = 0, bears = 0;

  // σ divergence (always shown if available, Dr S backbone signal)
  if(sd20 !== null) {
    if(sd20 >= 2.0) {
      lines.push({c:'#ef4444', t:'σ ' + sd20.toFixed(2) + ' DANGER — sectors diverging, bull coming apart (Dr S Mar 9)'});
      bears++;
    } else if(sd20 >= 1.5) {
      lines.push({c:'#f97316', t:'σ ' + sd20.toFixed(2) + ' WARNING — hidden weakness (Dr S Mar 9)'});
    } else if(sd20 < 0.5) {
      lines.push({c:'#22c55e', t:'σ ' + sd20.toFixed(2) + ' CALM — broad participation'});
    }
  }

  // 50D breadth — primary Dr S edge
  if(b50 !== null) {
    if(b50 <= 25) {
      lines.push({c:'#22c55e', t:'50D ' + b50 + '% bottom Q — bounce edge ~4x normal next 5d (Dr S Jan 21)'});
      bulls++;
    } else if(b50 >= 75) {
      lines.push({c:'#ef4444', t:'50D ' + b50 + '% top Q — next 5d only +0.11% subnormal (Dr S Jan 21)'});
      bears++;
    } else if(b50 > 50) {
      lines.push({c:'#aaccee', t:'50D ' + b50 + '% upper half — bull structure, pullbacks buyable (Dr S Jan 21)'});
    } else {
      lines.push({c:'#aaccee', t:'50D ' + b50 + '% lower half — watching'});
    }
  }

  // 200D breadth — structural edge
  if(b200 !== null) {
    if(b200 <= 25) {
      lines.push({c:'#22c55e', t:'200D ' + b200 + '% bottom Q — next 10d SPY +1.32% (Dr S)'});
      bulls++;
    } else if(b200 >= 75) {
      lines.push({c:'#ef4444', t:'200D ' + b200 + '% top Q — next 10d SPY -0.04% (Dr S)'});
      bears++;
    }
  }

  // BB Breadth — Dr S Jan 19
  if(bb !== null && bbQ25 !== null) {
    if(bb <= bbQ25) {
      lines.push({c:'#22c55e', t:'BB breadth ' + bb + '% lowest Q — next 30d 3x normal (Dr S Jan 19)'});
      bulls++;
    } else if(bbQ75 !== null && bb >= bbQ75) {
      lines.push({c:'#ef4444', t:'BB breadth ' + bb + '% highest Q — subnormal next 30d (Dr S Jan 19)'});
      bears++;
    }
  }

  // PCRE sentiment — contrarian
  if(pcre !== null) {
    if(pcre >= pcQ75) {
      lines.push({c:'#22c55e', t:'$PCRE ' + pcre.toFixed(2) + ' top Q — fear, next 10d SPY +0.96% (Dr S)'});
      bulls++;
    } else if(pcre <= pcQ25) {
      lines.push({c:'#ef4444', t:'$PCRE ' + pcre.toFixed(2) + ' bottom Q — greed, only +0.25% next 10d (Dr S)'});
      bears++;
    }
  }

  // RSI SPY 5-period — extreme
  if(rsi !== null) {
    if(rsi >= 70) {
      lines.push({c:'#ef4444', t:'SPY RSI(5) ' + rsi.toFixed(1) + ' overbought — mean reversion risk'});
      bears++;
    } else if(rsi <= 30) {
      lines.push({c:'#22c55e', t:'SPY RSI(5) ' + rsi.toFixed(1) + ' oversold — bounce likely'});
      bulls++;
    }
  }

  // XLE rotation — Dr S Jan 16
  const xleR = window.xleRotation;
  if(xleR && xleR.current >= xleR.q90) {
    lines.push({c:'#ef4444', t:'XLE vs SPY extreme — energy leading, SPY negative next 3-5d (Dr S Jan 16)'});
    bears++;
  } else if(xleR && xleR.current >= xleR.q50) {
    lines.push({c:'#f97316', t:'XLE vs SPY top half — energy leading, SPY subnormal forward (Dr S Jan 16)'});
    bears++;
  }

  if(lines.length === 0) {
    box.style.display = 'none';
    return;
  }

  // Action line — Dr S combined read
  let action, actionColor, borderColor;
  if(bears >= 3 && bulls === 0) {
    action = 'DR S ACTION: ' + bears + ' bears stacked. Same-direction stack = high conviction. Do not chase. Size down. Wait for pullback.';
    actionColor = '#ef4444';
    borderColor = '#ef4444';
  } else if(bulls >= 3 && bears === 0) {
    action = 'DR S ACTION: ' + bulls + ' bulls stacked. High conviction reversal long. Buy weakness when lows stop expanding.';
    actionColor = '#22c55e';
    borderColor = '#22c55e';
  } else if(bears >= 2 && bulls === 0) {
    action = 'DR S ACTION: ' + bears + ' bears stacked — extended warning. Reduce size on longs. Take profits.';
    actionColor = '#f97316';
    borderColor = '#f97316';
  } else if(bulls >= 2 && bears === 0) {
    action = 'DR S ACTION: ' + bulls + ' bulls stacked — moderate long edge. Scale in on weakness.';
    actionColor = '#22c55e';
    borderColor = '#22c55e';
  } else if(bulls > 0 && bears > 0) {
    action = 'DR S ACTION: conflicting (' + bulls + ' bull / ' + bears + ' bear) — no edge, wait.';
    actionColor = '#eab308';
    borderColor = '#eab308';
  } else if(bears === 1) {
    action = 'DR S ACTION: 1 bear signal — caution but not decisive.';
    actionColor = '#aaccee';
    borderColor = '#6b7a8f';
  } else if(bulls === 1) {
    action = 'DR S ACTION: 1 bull signal — wait for confirmation.';
    actionColor = '#aaccee';
    borderColor = '#6b7a8f';
  } else {
    action = 'DR S ACTION: no extreme signals — neutral environment.';
    actionColor = '#aaccee';
    borderColor = '#6b7a8f';
  }

  linesEl.innerHTML = lines.map(l => `<div style="color:${l.c};margin-bottom:2px">• ${l.t}</div>`).join('');
  actionEl.style.color = actionColor;
  actionEl.textContent = action;
  box.style.borderLeftColor = borderColor;
  box.style.display = 'block';
}

