      window.pcreQ25 = pcreData.q25;
      window.pcreQ75 = pcreData.q75;
      if(typeof updatePcreCard === 'function') updatePcreCard();
    }

    if(rsiData) {
      window.rsiData = rsiData;
      window.rsiValue = rsiData.current;  // keep alignment function in sync
      const rsiInput = document.getElementById('rsiInput');
      if(rsiInput) rsiInput.value = rsiData.current.toFixed(1);
      const rsiSrc = document.getElementById('rsiSource');
      if(rsiSrc) { rsiSrc.textContent = '(LIVE)'; rsiSrc.style.color = '#22c55e'; }
      if(typeof updateRsiCard === 'function') updateRsiCard();
    }

    // Single alignment refresh after all signals are in
    if(typeof updateAlignmentCard === 'function') updateAlignmentCard();

    // Re-run regime classification now that PCRE, RSI, BB data are all loaded
    // so the bear-stack modifier on the BULL MARKET regime can reflect live signals
    if(typeof update === 'function') update();

    const dateLabel = results[0]?.date || 'today';
    document.querySelector('.header div div:first-child').textContent = `DATA AS OF ${dateLabel}`;
    document.querySelector('.header div div:last-child').style.color = '#22c55e';
    document.querySelector('.header div div:last-child').textContent = 'LIVE DATA ✓';
    return realMaData;
  } catch(e) {
    console.error('Data fetch error:', e);
    setStatus('error');
    return null;
  }
}

