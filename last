function parseCSV(text, ticker) {
  const rejoined = text.replace(/(\d{4}-\d{2}-)\r?\n(\d{2},)/g, '$1$2');
  const lines = rejoined.trim().split('\n').filter(l => l.trim());
  if(lines.length < 2) return null;
  const headers = lines[0].split(',').map(h => h.trim());
  const lastRow  = lines[lines.length - 1].split(',');
  const result = { ticker, date: lastRow[0]?.trim() };
  const mas = [3, 5, 10, 20, 50, 100, 200];
  for(const ma of mas) {
    const idx = headers.findIndex(h => {
      const u = h.toUpperCase();
      return u.includes(`PCTASMA${ma}`) && !u.includes('RANGESD') && !u.includes('|');
    });
    result[ma] = idx >= 0 ? parseFloat(lastRow[idx]) : null;
  }

  return result;
}

async function fetchCSV(ticker, url) {
  const proxies = [
    `/.netlify/functions/fetch-csv?url=${encodeURIComponent(url)}&t=${Date.now()}`,
    `https://corsproxy.io/?url=${encodeURIComponent(url)}`,
    `https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`
  ];
  let lastError;
  for (const proxy of proxies) {
    try {
      const res = await fetch(proxy);
      if(!res.ok) throw new Error(`${ticker} fetch failed: ${res.status}`);
      const text = await res.text();
      if(text && text.length > 100) return parseCSV(text, ticker);
    } catch(e) { lastError = e; }
  }
  throw lastError || new Error(`${ticker} all proxies failed`);
}

async function fetchBollingerBand() {
  const proxies = [
    `/.netlify/functions/fetch-csv?url=${encodeURIComponent(BB_URL)}&t=${Date.now()}`,
    `https://corsproxy.io/?url=${encodeURIComponent(BB_URL)}`,
