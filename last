// Fixed thresholds directly from Dr S post:
// Above 75% = top quartile = overbought — next 5 days subnormal +0.11%
// Below 25% = bottom quartile = oversold — next 5 days edge active ~4x normal
function updateBreadth50Card() {
  const d = window.breadth50Data;
  if(!d || d.current === null) return;
  const card  = document.getElementById('breadth50Card');
  const label = document.getElementById('breadth50Label');
  const sub   = document.getElementById('breadth50Sub');
  const desc  = document.getElementById('breadth50Desc');
  const val   = d.current;

  if(val >= 75) {
    card.style.background = '#1a0a02';
    card.style.border     = '1px solid #f9731650';
    label.style.color     = '#f97316';
    label.textContent     = val + '%  TOP QUARTILE';
    sub.style.color       = '#f97316';
    sub.textContent       = 'OVERBOUGHT — NEXT 5 DAYS SUBNORMAL';
    desc.textContent      = 'Above 75% — Dr S top quartile. Next 5 day SPY returns average only +0.11%. Do not chase. Short term pullback likely. Long term pullbacks are still buying opportunities.';
  } else if(val <= 25) {
    card.style.background = '#021408';
    card.style.border     = '1px solid #22c55e50';
    label.style.color     = '#22c55e';
    label.textContent     = val + '%  BOTTOM QUARTILE';
    sub.style.color       = '#22c55e';
    sub.textContent       = 'OVERSOLD — BOUNCE EDGE ACTIVE';
