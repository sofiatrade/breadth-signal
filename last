  ];
  for(const proxy of proxies) {
    try {
      const res = await fetch(proxy);
      if(!res.ok) continue;
      const text = await res.text();
      if(!text || text.length < 100) continue;
      const lines = text.trim().split('\n').filter(l => l.trim());
      if(lines.length < 2) continue;
      const headers = lines[0].split(',').map(h => h.trim());
      const bbIdx = headers.findIndex(h => h.toUpperCase().includes('PCTABBUPPER'));
      if(bbIdx < 0) continue;
      const lastRow = lines[lines.length - 1].split(',');
      const val = parseFloat(lastRow[bbIdx]);
      if(isNaN(val)) continue;
      const allVals = lines.slice(1).map(l => parseFloat(l.split(',')[bbIdx])).filter(v => !isNaN(v));
      allVals.sort((a,b) => a - b);
      const q25 = allVals[Math.floor(allVals.length * 0.25)];
      const q75 = allVals[Math.floor(allVals.length * 0.75)];
      return { current: Math.round(val * 100) / 100, q25: Math.round(q25*100)/100, q75: Math.round(q75*100)/100 };
    } catch(e) { continue; }
  }
  return null;
}

async function fetchBollingerLower() {
  try {
    const res = await fetch(`/.netlify/functions/fetch-csv?url=${encodeURIComponent(BB_LOWER_URL)}&t=${Date.now()}`);
    if(!res.ok) return null;
    const text = await res.text();
    if(!text || text.length < 100) return null;
    const lines = text.trim().split('\n').filter(l => l.trim());
    if(lines.length < 2) return null;
    const headers = lines[0].split(',').map(h => h.trim());
    const bbIdx = headers.findIndex(h => h.toUpperCase().includes('BELOW') || h.toUpperCase().includes('PCTBELOWLOWER'));
    if(bbIdx < 0) return null;
    const lastRow = lines[lines.length - 1].split(',');
    const val = parseFloat(lastRow[bbIdx]);
    if(isNaN(val)) return null;
    const allVals = lines.slice(1).map(l => parseFloat(l.split(',')[bbIdx])).filter(v => !isNaN(v));
    allVals.sort((a,b) => a - b);
    const q25 = allVals[Math.floor(allVals.length * 0.25)];
    const q75 = allVals[Math.floor(allVals.length * 0.75)];
    return { current: Math.round(val*100)/100, q25: Math.round(q25*100)/100, q75: Math.round(q75*100)/100 };
  } catch(e) { return null; }
}

async function loadRealData() {
  setStatus('loading');
  try {
    const [results, bbData] = await Promise.all([
      Promise.all(SECTORS.map(s => fetchCSV(s, CSV_URLS[s]))),
      fetchBollingerBand()
    ]);
    const valid = results.filter(r => r && r[20] !== null);
    if(valid.length < 8) throw new Error('Too many sectors failed');
    const mas = [3, 5, 10, 20, 50, 100, 200];
    const realMaData = mas.map(ma => ({
      ma,
      label: ma + 'D',
      sd: calcSD(SECTORS.map((s,i) => results[i]?.[ma] ?? 50)),
      vals: SECTORS.map((s,i) => results[i]?.[ma] ?? 50),
    }));
    const currentAvg50  = results.reduce((sum, r) => sum + (r?.[50]  ?? 50), 0) / results.length;
    const currentAvg5   = results.reduce((sum, r) => sum + (r?.[5]   ?? 50), 0) / results.length;
    const currentAvg100 = results.reduce((sum, r) => sum + (r?.[100] ?? 50), 0) / results.length;
    const currentAvg200 = results.reduce((sum, r) => sum + (r?.[200] ?? 50), 0) / results.length;
    window.breadth50Data  = { current: Math.round(currentAvg50  * 10) / 10 };
    window.breadth5Data   = { current: Math.round(currentAvg5   * 10) / 10 };
    window.breadth100Data = { current: Math.round(currentAvg100 * 10) / 10 };
    window.breadth200Data = { current: Math.round(currentAvg200 * 10) / 10 };
    window.maData = realMaData;
    updateBreadth50Card();
    updateBreadth5Card();
    updateBreadth100Card();
    updateBreadth200Card();
    updateAlignmentCard();
    if(bbData) { window.bbData = bbData; }
    const bbLowerData = await fetchBollingerLower();
    if(bbLowerData) { window.bbLowerData = bbLowerData; }
    if(window.bbData || window.bbLowerData) updateBollingerCard();
    updateAlignmentCard();

    const dateLabel = results[0]?.date || 'today';
    document.querySelector('.header div div:first-child').textContent = `DATA AS OF ${dateLabel}`;
    document.querySelector('.header div div:last-child').style.color = '#22c55e';
